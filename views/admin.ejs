<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>

  <body class="bg-light">

    <div class="container py-4">

      <!-- Title -->
      <h1 class="mb-4 text-center"><%= title %></h1>

      <!-- Message -->
      <% if (message) { %>
        <div class="alert <%= messageType %>"><%= message %></div>
      <% } %>

      <!-- Timer Controls -->
      <div class="card shadow-sm mb-4">
        <div class="card-body">

          <h5 class="card-title mb-3">Timer‑Steuerung</h5>

          <div id="timer-display" class="fw-bold mb-3">Timer: 00:00</div>
          <div id="winner-message" class="mb-3"></div>

          <div class="d-flex gap-2 mb-3">
            <button id="start-timer" class="btn btn-success w-50">Timer starten</button>
            <button id="stop-timer" class="btn btn-danger w-50">Timer stoppen</button>
          </div>

          <!-- Auto Start -->
          <div class="border rounded p-3 bg-light">
            <h6 class="fw-bold mb-2">Automatischer Start</h6>

            <div class="d-flex align-items-center gap-2 mb-2">
              <input id="auto-start-enabled" type="checkbox" class="form-check-input">
              <label class="form-check-label">Automatisch starten um</label>

              <input id="auto-start-time" type="text" placeholder="hh:mm" maxlength="5"
                     class="form-control" style="width: 90px;">
            </div>

            <button id="save-auto-start" class="btn btn-primary btn-sm">Speichern</button>

            <div id="auto-start-status" class="mt-2 fw-bold text-secondary">
              Status: deaktiviert
            </div>
          </div>

        </div>
      </div>

      <!-- Votes -->
      <div class="card shadow-sm">
        <div class="card-body">

          <h5 class="card-title mb-3">Eingereichte Votes</h5>

          <ul id="vote-list" class="list-group mb-3">
            <% data.forEach(function(item) { %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                  <strong><%= item.name %></strong> – <%= item.time %>
                </div>

                <form action="/delete" method="POST" class="m-0">
                  <input type="hidden" name="name" value="<%= item.name %>">
                  <button class="btn btn-sm btn-outline-danger">Löschen</button>
                </form>
              </li>
            <% }); %>
          </ul>

          <form action="/reset" method="POST">
            <button class="btn btn-warning w-100">Alle löschen</button>
          </form>

        </div>
      </div>

    </div>

    <!-- Socket.IO -->
    <script src="/socket.io/socket.io.js"></script>

    <!-- Admin Logic -->
    <script>
      const socket = io();
      const voteList = document.getElementById('vote-list');
      let timerInterval = null;
      let activeTimerStartedAt = null;
      let timerElapsedBase = 0;
      let currentVotes = <%- JSON.stringify(data) %>;
      let currentWinner = null;

      function escapeHtml(value) {
        return String(value)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/\"/g, '&quot;');
      }

      function formatTime(seconds) {
        const safeSeconds = Math.max(0, seconds);
        const minutes = String(Math.floor(safeSeconds / 60)).padStart(2, '0');
        const remainingSeconds = String(safeSeconds % 60).padStart(2, '0');
        return minutes + ':' + remainingSeconds;
      }

      function renderTimer(state) {
        const timerDisplay = document.getElementById('timer-display');
        if (!state || !state.active) {
          timerDisplay.textContent = 'Timer: ' + formatTime(state?.elapsedSeconds || 0);
          return;
        }
        timerDisplay.textContent = 'Timer: ' + formatTime(state.elapsedSeconds || 0);
      }

      function startLocalTimer(startedAt, initialElapsedSeconds) {
        clearInterval(timerInterval);

        if (!startedAt) {
          renderTimer({ active: false, elapsedSeconds: initialElapsedSeconds || 0 });
          return;
        }

        activeTimerStartedAt = startedAt;
        timerElapsedBase = initialElapsedSeconds || 0;
        renderTimer({ active: true, elapsedSeconds: timerElapsedBase });

        timerInterval = setInterval(() => {
          const elapsedSeconds = timerElapsedBase + Math.floor((Date.now() - activeTimerStartedAt) / 1000);
          renderTimer({ active: true, elapsedSeconds });
        }, 1000);
      }

      function stopLocalTimer(elapsedSeconds) {
        clearInterval(timerInterval);
        timerInterval = null;

        activeTimerStartedAt = null;
        timerElapsedBase = elapsedSeconds || 0;
        renderTimer({ active: false, elapsedSeconds: timerElapsedBase });
      }

      function renderWinnerMessage(winner) {
        const winnerMessage = document.getElementById('winner-message');
        if (!winner) {
          winnerMessage.textContent = '';
          return;
        }

        winnerMessage.textContent = `Gewinner: ${winner.name} – ${winner.time}`;
        winnerMessage.classList.add('text-success', 'fw-bold');
      }

      function renderVotes(votes, winner) {
        currentVotes = votes || [];
        currentWinner = winner || null;

        voteList.innerHTML = currentVotes.map(item => {
          const isWinner = currentWinner &&
            currentWinner.name === item.name &&
            currentWinner.time === item.time;

          return `
            <li class="list-group-item d-flex justify-content-between align-items-center ${isWinner ? 'list-group-item-success fw-bold' : ''}">
              <div>
                ${escapeHtml(item.name)} – ${escapeHtml(item.time)}
              </div>
              <form action="/delete" method="POST" class="m-0">
                <input type="hidden" name="name" value="${escapeHtml(item.name)}">
                <button class="btn btn-sm btn-outline-danger">Löschen</button>
              </form>
            </li>
          `;
        }).join('');

        renderWinnerMessage(currentWinner);
      }

      document.getElementById('start-timer').addEventListener('click', () => {
        socket.emit('timer:start');
      });

      document.getElementById('stop-timer').addEventListener('click', () => {
        socket.emit('timer:stop');
      });

      document.getElementById('save-auto-start').addEventListener('click', () => {
        const enabled = document.getElementById('auto-start-enabled').checked;
        const timeInput = document.getElementById('auto-start-time').value;
        socket.emit('timer:autoStart', { enabled, time: timeInput });
      });

      renderVotes(<%- JSON.stringify(data) %>);

      socket.on('connect', () => socket.emit('timer:getState'));

      socket.on('votesUpdated', payload => {
        renderVotes(payload.data || [], null);
      });

      socket.on('timerState', state => {
        if (!state || !state.active) {
          stopLocalTimer(state?.elapsedSeconds || 0);
          renderVotes(currentVotes, state?.winner || null);
          return;
        }

        startLocalTimer(state.startedAt, state.elapsedSeconds || 0);
        renderVotes(currentVotes, state?.winner || null);
      });

      socket.on('timerStarted', payload => {
        startLocalTimer(payload.startedAt, 0);
        renderVotes(currentVotes, null);
      });

      socket.on('timerStopped', payload => {
        stopLocalTimer(payload.elapsedSeconds || 0);
        renderVotes(currentVotes, payload.winner || null);
      });

      socket.on('timerAutoSettings', payload => {
        document.getElementById('auto-start-enabled').checked = !!payload.enabled;
        document.getElementById('auto-start-time').value = payload.time || '';

        const status = document.getElementById('auto-start-status');
        if (payload.enabled && payload.time) {
          status.textContent = 'Status: aktiviert für ' + payload.time;
          status.classList.remove('text-secondary');
          status.classList.add('text-success');
        } else {
          status.textContent = 'Status: deaktiviert';
          status.classList.remove('text-success');
          status.classList.add('text-secondary');
        }
      });
    </script>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

  </body>
</html>
