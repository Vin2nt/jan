<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Error</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>

  <body class="bg-light">

    <div class="container py-5">

      <div class="row justify-content-center">
        <div class="col-md-8">

          <div class="card shadow-sm border-danger">
            <div class="card-body">

              <div class="text-center mb-4">
                <div class="display-4 text-danger fw-bold">Fehler</div>
              </div>

              <h3 class="text-danger text-center mb-3"><%= message %></h3>
              <h5 class="text-secondary text-center mb-4">Status: <%= error.status %></h5>

              <div class="bg-light p-3 border rounded" style="white-space: pre-wrap;">
                <pre class="m-0"><%= error.stack %></pre>
              </div>

              <div class="text-center mt-4">
                <a href="/" class="btn btn-primary btn-lg">
                  Zurück zur Startseite
                </a>
              </div>

            </div>
          </div>

        </div>
      </div>

    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

  </body>
</html>
